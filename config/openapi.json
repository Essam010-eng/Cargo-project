{
  "openapi": "3.0.3",
  "info": {
    "title": "Car Go API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://cargo-project-production.up.railway.app"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      },
      "AuthRegisterRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string", "minLength": 6 },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["admin", "seller"] }
        },
        "required": ["username", "password", "email", "role"]
      },
      "AuthLoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": { "type": "object" },
          "token": { "type": "string" }
        },
        "required": ["token"]
      },
      "Product": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "price": { "type": "number" },
          "stock": { "type": "number" },
          "carsforproduct": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            }
          },
          "colorimage": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "color": { "type": "string" },
                "images": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "owner": { "type": "string" },
          "averageRating": { "type": "number" },
          "createdAt": { "type": "string" }
        }
      },
      "CreateProductRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "price": { "type": "number" },
          "stock": { "type": "number" },
          "carsforproduct": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            }
          },
          "color": { "type": "string" },
          "images": { "type": "array", "items": { "type": "string", "format": "binary" } },
          "owner": { "type": "string" }
        },
        "required": ["name", "description", "category", "price", "stock"]
      },
      "CreateOrderRequest": {
        "type": "object",
        "properties": {
          "products": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "product": { "type": "string" },
                "quantity": { "type": "number" },
                "price": { "type": "number" }
              },
              "required": ["product", "quantity", "price"]
            }
          }
        },
        "required": ["products"]
      },
      "UpdateOrderStatusRequest": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["pending", "shipping", "delivered"] }
        },
        "required": ["status"]
      },
      "Review": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "user": { "type": "string" },
          "product": { "type": "string" },
          "rating": { "type": "number" },
          "comment": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      },
      "CreateReviewRequest": {
        "type": "object",
        "properties": {
          "product": { "type": "string" },
          "rating": { "type": "number", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string", "maxLength": 500 }
        },
        "required": ["product", "rating"]
      },
      "UpdateReviewRequest": {
        "type": "object",
        "properties": {
          "rating": { "type": "number", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string", "maxLength": 500 }
        }
      },
      "DetectDamageResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": { "type": "object" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["admin", "seller"] },
          "createdAt": { "type": "string" }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth" },
    { "name": "Products" },
    { "name": "Orders" },
    { "name": "Users" },
    { "name": "Reviews" },
    { "name": "Card Damage" },
    { "name": "Recommendation" }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRegisterRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthLoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/api/product": {
      "get": {
        "tags": ["Products"],
        "summary": "Get all products (admin only)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create product (admin/seller, multipart)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/CreateProductRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/api/product/{name}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get one product by name (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/api/product/{id}": {
      "patch": {
        "tags": ["Products"],
        "summary": "Update product patch (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update product put (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/product/seller": {
      "get": {
        "tags": ["Products"],
        "summary": "Get products for logged seller",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/product/seller/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get one seller product by name (seller)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "patch": {
        "tags": ["Products"],
        "summary": "Update seller product patch (seller)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update seller product put (seller)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete seller product (seller)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/order/": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order (auth)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/order/my": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get my orders (auth)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/order/{id}": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateOrderStatusRequest" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/order": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get all orders (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/user": {
      "get": {
        "tags": ["Users"],
        "summary": "Get all users (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/user/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user by id (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update logged user (auth)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete user (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/review": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Create review (auth)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateReviewRequest" }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      },
      "get": {
        "tags": ["Reviews"],
        "summary": "Get all reviews",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/review/product/{productId}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get reviews for a product",
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/review/{id}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get one review",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "tags": ["Reviews"],
        "summary": "Update review (auth)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "Delete review (auth)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/api/detect-damage": {
      "post": {
        "tags": ["Card Damage"],
        "summary": "Detect card damage (multipart image)",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": { "type": "string", "format": "binary" }
                },
                "required": ["image"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DetectDamageResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "500": { "description": "Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },

    "/api/recommend/content": {
      "get": {
        "tags": ["Recommendation"],
        "summary": "Recommendations by content",
        "parameters": [
          { "name": "itemName", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "400": { "description": "Bad Request" } }
      }
    },
    "/api/recommend/trending": {
      "get": {
        "tags": ["Recommendation"],
        "summary": "Trending recommendations",
        "parameters": [
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/recommend/user": {
      "get": {
        "tags": ["Recommendation"],
        "summary": "Collaborative recommendations",
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "400": { "description": "Bad Request" } }
      }
    }
  }
}

